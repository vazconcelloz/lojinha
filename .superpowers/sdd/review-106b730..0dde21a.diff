+++        _salesService = new SalesService(_context, _stockService);
+++
+++        _category = new Category { Nome = "Bebidas" };
+++        _context.Categories.Add(_category);
+++        _context.SaveChanges();
+++
+++        _product = new Product
+++        {
+++            Nome = "Coca-Cola 2L",
