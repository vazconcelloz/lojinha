+++            _snackbar.Show("Sucesso", $"Caixa fechado. Diferença: {sessao.Diferenca:C}", ControlAppearance.Success);
+++        }
+++        catch (Exception ex)
+++        {
+++            _snackbar.Show("Erro", ex.Message, ControlAppearance.Danger);
+++        }
+++    }
+++}
