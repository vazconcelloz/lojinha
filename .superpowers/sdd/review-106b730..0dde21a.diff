++++    }
++++
++++    private void Carregar()
++++    {
++++        SessaoAtual = _caixaService.GetSessaoAberta();
++++        Movimentos.Clear();
++++        if (SessaoAtual is not null)
++++        {
++++            foreach (var movimento in _caixaService.GetMovimentos(SessaoAtual.Id))
++++            {
++++                Movimentos.Add(movimento);
++++            }
++++        }
