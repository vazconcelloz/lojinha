+++        var movimento = _service.RegistrarMovimento(TipoMovimentoCaixa.Sangria, 30m, "admin1", "Depósito banco");
+++
+++        Assert.Equal(sessao.Id, movimento.CaixaSessaoId);
+++        Assert.Equal(TipoMovimentoCaixa.Sangria, movimento.Tipo);
